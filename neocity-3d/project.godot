; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Neo City 3D"
config/description="AI-Powered Cyberpunk MMO World — QuantNeon"
config/tags=PackedStringArray("3d", "multiplayer", "cyberpunk")
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

ReactBridge="*res://scripts/react_bridge.gd"
SocketIOClient="*res://scripts/socket_io_client.gd"
NetworkManager="*res://scripts/network_manager.gd"
EnvironmentManager="*res://scripts/environment_manager.gd"
DialogueSystem="*res://ui/dialogue_box.tscn"
ShopSystem="*res://scripts/shop_system.gd"
ShopUI="*res://ui/shop_ui.tscn"
WeaponSystem="*res://scripts/weapon_system.gd"
CombatHUD="*res://ui/combat_hud.tscn"
WantedHUD="*res://ui/wanted_hud.tscn"
MissionHUD="*res://ui/mission_hud.tscn"
ObjectiveMarker="*res://scripts/objective_marker.gd"
InventoryUI="*res://ui/inventory_ui.tscn"
VehicleMissionHUD="*res://ui/vehicle_mission_hud.tscn"
PropertyManager="*res://scripts/property_manager.gd"
LandOwnershipService="*res://scripts/LandOwnershipService.gd"
RentEconomy="*res://scripts/RentEconomy.gd"
BuildingDecaySystem="*res://scripts/BuildingDecaySystem.gd"
RealEstateUI="*res://ui/real_estate_ui.tscn"
TraderUI="*res://ui/trader_ui.tscn"
CyberneticsUI="*res://ui/cybernetics_ui.tscn"
CyberdeckUI="*res://ui/cyberdeck_ui.tscn"
EventHUD="*res://ui/event_hud.tscn"
LandOwnershipUI="*res://ui/land_ownership_ui.tscn"
RentEconomyUI="*res://ui/rent_economy_ui.tscn"
CityLeaderboardUI="*res://ui/city_leaderboard_ui.tscn"
FactionManager="*res://scripts/services/FactionManager.gd"
TerritoryWar="*res://scripts/services/TerritoryWar.gd"
SeasonSystem="*res://scripts/services/SeasonSystem.gd"
MiniGameSystem="*res://scripts/games/MiniGameSystem.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="viewport"

