# Environment Configuration
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/quantneon

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Secrets (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long
JWT_EXPIRY=7d

# Quantmail SSO
QUANTMAIL_JWT_SECRET=quantmail-shared-secret-or-public-key
QUANTMAIL_ISSUER=quantmail

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
SSO_RATE_LIMIT_MAX=10

# CORS
CORS_ORIGIN=http://localhost:3000

# S3 (optional for local development)
S3_BUCKET=quantneon-uploads
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# AI Providers for NeonFeed (optional - falls back to heuristic ranking)
AI_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
